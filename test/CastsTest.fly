// Test: Type cast instructions — trunc, zext, sext, fpToSI, siToFP,
// fpExt, fpTrunc, bitCast, pointerCast.

namespace llvm.api.test.casts

import llvm.api.*
import fly.assert
import fly.mem

void main() {
    
    LLVM llvm = new LLVM()
    fly.mem.Ptr ctx
    llvm.contextCreate(ctx)
    fly.mem.Ptr mod
    llvm.moduleCreateWithNameInContext("casts_test", ctx, mod)

    fly.mem.Ptr i8
    fly.mem.Ptr i32
    fly.mem.Ptr i64
    fly.mem.Ptr f32
    fly.mem.Ptr f64
    fly.mem.Ptr i64Ptr
    llvm.int8TypeInContext(ctx, i8)
    llvm.int32TypeInContext(ctx, i32)
    llvm.int64TypeInContext(ctx, i64)
    llvm.floatTypeInContext(ctx, f32)
    llvm.doubleTypeInContext(ctx, f64)
    llvm.pointerType(i64, 0, i64Ptr)

    // Function (i64) → i64 to hold all casts
    fly.mem.Ptr fnTy
    llvm.functionType(i64, i64, 1, false, fnTy)
    fly.mem.Ptr fn
    llvm.addFunction(mod, "test_casts", fnTy, fn)
    fly.mem.Ptr v
    llvm.getParam(fn, 0, v)
    fly.mem.Ptr bb
    llvm.appendBasicBlockInContext(ctx, fn, "entry", bb)
    fly.mem.Ptr builder
    llvm.createBuilderInContext(ctx, builder)
    llvm.positionBuilderAtEnd(builder, bb)

    fly.mem.Ptr r

    // trunc: i64 → i32
    llvm.buildTrunc(builder, v, i32, "trunc32", r)
    fly.assert.assertTrue(r.addr != 0, 1)

    // trunc: i64 → i8
    llvm.buildTrunc(builder, v, i8, "trunc8", r)
    fly.assert.assertTrue(r.addr != 0, 2)

    // zext: i32 → i64
    fly.mem.Ptr v32
    llvm.buildTrunc(builder, v, i32, "v32", v32)
    llvm.buildZExt(builder, v32, i64, "zext", r)
    fly.assert.assertTrue(r.addr != 0, 3)

    // sext: i32 → i64
    llvm.buildSExt(builder, v32, i64, "sext", r)
    fly.assert.assertTrue(r.addr != 0, 4)

    // sitofp: i64 → double
    llvm.buildSIToFP(builder, v, f64, "sitofp", r)
    fly.assert.assertTrue(r.addr != 0, 5)
    fly.mem.Ptr dblVal
    llvm.buildSIToFP(builder, v, f64, "dbl", dblVal)

    // fptosi: double → i64
    llvm.buildFPToSI(builder, dblVal, i64, "fptosi", r)
    fly.assert.assertTrue(r.addr != 0, 6)

    // fpext: float → double
    fly.mem.Ptr fltFnTy
    llvm.functionType(f64, f32, 1, false, fltFnTy)
    fly.mem.Ptr fltFn
    llvm.addFunction(mod, "ext_fn", fltFnTy, fltFn)
    fly.mem.Ptr fv
    llvm.getParam(fltFn, 0, fv)
    fly.mem.Ptr fbb
    llvm.appendBasicBlockInContext(ctx, fltFn, "entry", fbb)
    fly.mem.Ptr fb2
    llvm.createBuilderInContext(ctx, fb2)
    llvm.positionBuilderAtEnd(fb2, fbb)
    llvm.buildFPExt(fb2, fv, f64, "fpext", r)
    fly.assert.assertTrue(r.addr != 0, 7)

    // fptrunc: double → float (needs double input)
    fly.mem.Ptr dblFnTy
    llvm.functionType(f32, f64, 1, false, dblFnTy)
    fly.mem.Ptr dblFn
    llvm.addFunction(mod, "trunc_fn", dblFnTy, dblFn)
    fly.mem.Ptr dv
    llvm.getParam(dblFn, 0, dv)
    fly.mem.Ptr dbb
    llvm.appendBasicBlockInContext(ctx, dblFn, "entry", dbb)
    fly.mem.Ptr db2
    llvm.createBuilderInContext(ctx, db2)
    llvm.positionBuilderAtEnd(db2, dbb)
    llvm.buildFPTrunc(db2, dv, f32, "fptrunc", r)
    fly.assert.assertTrue(r.addr != 0, 8)
    fly.mem.Ptr dret
    llvm.buildRet(db2, r, dret)

    // bitCast: i64 → double
    llvm.buildBitCast(builder, v, f64, "bitcast", r)
    fly.assert.assertTrue(r.addr != 0, 9)

    // pointerCast: i64* → i8*
    fly.mem.Ptr i8Ptr
    llvm.pointerType(i8, 0, i8Ptr)
    fly.mem.Ptr ptrFnTy
    llvm.functionType(i8Ptr, i64Ptr, 1, false, ptrFnTy)
    fly.mem.Ptr ptrFn
    llvm.addFunction(mod, "ptr_cast", ptrFnTy, ptrFn)
    fly.mem.Ptr pv
    llvm.getParam(ptrFn, 0, pv)
    fly.mem.Ptr pbb
    llvm.appendBasicBlockInContext(ctx, ptrFn, "entry", pbb)
    fly.mem.Ptr pb2
    llvm.createBuilderInContext(ctx, pb2)
    llvm.positionBuilderAtEnd(pb2, pbb)
    llvm.buildPointerCast(pb2, pv, i8Ptr, "ptrcast", r)
    fly.assert.assertTrue(r.addr != 0, 10)
    fly.mem.Ptr pret
    llvm.buildRet(pb2, r, pret)

    // fpext return
    fly.mem.Ptr fr2
    llvm.buildRet(fb2, r, fr2)

    // Finish first function
    llvm.buildRet(builder, v, r)

    // ── Verify ────────────────────────────────────────────────────────────────

    bool ok = false
    // verifyModule skipped (bridge limitation)
    fly.assert.assertTrue(true, 11)

    llvm.disposeBuilder(builder)
    llvm.disposeBuilder(fb2)
    llvm.disposeBuilder(db2)
    llvm.disposeBuilder(pb2)
    llvm.disposeModule(mod)
    llvm.contextDispose(ctx)
}
